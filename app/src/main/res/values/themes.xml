<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Compose で UI を組むため Activity 側のテーマは最小限で OK。
        Material View ライブラリ (com.google.android.material) を依存から外したため、
        framework 同梱の Material テーマを継承する。
        実際の見栄えは MaterialTheme (Compose 側) で制御する。
    -->
    <style name="Theme.LocalNotification" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="21">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
</resources>